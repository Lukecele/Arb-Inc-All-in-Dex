{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arb-inc-dex-aggregator",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}
