# Cloudflare Pages - Environment Variables

# Node version (set in Pages dashboard, not needed here)
# NODE_VERSION=18

# Optional: Custom RPC URLs if you want to use different ones
# BSC_RPC_URL=https://bsc.publicnode.com

# Optional: WalletConnect Project ID (for WalletConnect support)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=b03ed6d8451c1e05022897815db0ad0b

# Optional: Analytics (if you add them later)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Custom fee receiver address
# FEE_RECEIVER_ADDRESS=0xafF5340ECFaf7ce049261cff193f5FED6BDF04E7

# Mailchimp newsletter integration
# MAILCHIMP_API_KEY=your-api-key-usX
# MAILCHIMP_LIST_ID=your-audience-id
